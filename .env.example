# ---------------------------------------------------------------------------
# MediChain E-MedicVault - Environment Template (SAFE TO COMMIT)
# Copy this file to `.env` and fill in real secrets. `.env` itself is git-ignored.
# ---------------------------------------------------------------------------

# Cryptographic master secret consumed by CryptoVault (crypto_vault.php).
# Generate a strong value, e.g.:  php -r "echo base64_encode(random_bytes(32));"
APP_MASTER_KEY=change-me-to-a-long-random-secret

# Database connection (use a LEAST-PRIVILEGE account, never root).
DB_HOST=127.0.0.1
DB_NAME=medic_vault_db
DB_USER=app_user
DB_PASS=change-me
